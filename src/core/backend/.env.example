# Backend Environment Variables (FastAPI)
# Copy this file to .env and fill in your actual values

# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Get this from your Neon dashboard
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ─── Authentication ───────────────────────────────────────────────────────────
# URL of the Next.js frontend — backend fetches the JWKS public keys from here
# to verify JWT tokens issued by Better Auth
# Format: http(s)://your-frontend-url  (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ─── Application ─────────────────────────────────────────────────────────────
DEBUG=True
